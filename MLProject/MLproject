name: titanic_model

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      n_estimators:
        type: int
        default: 100
      max_depth:
        type: int
        default: 5
      test_size:
        type: float
        default: 0.2
      random_state:
        type: int
        default: 42
    command: >
      python modelling.py
        --n_estimators {n_estimators}
        --max_depth {max_depth}
        --test_size {test_size}
        --random_state {random_state}
